{
  "schemaVersion": 1,
  "current": "quality-gates-wired",
  "node": {
    "nodeVersion": "24.14.1",
    "eslint": "9.39.4",
    "typescriptEslint": "8.57.2",
    "typescript": "5.9.3",
    "prettier": "3.8.1",
    "strictTypecheck": true,
    "commands": [
      "npm run format:check",
      "npm run lint",
      "npm run build",
      "npm run verify:tooling-refresh",
      "npm run verify:project-status",
      "npm run verify:dmg-packaging",
      "npm run verify:github-packaging",
      "typos ."
    ]
  },
  "rust": {
    "stableGates": [
      "cargo fmt --all --check --manifest-path src-tauri/Cargo.toml",
      "cargo clippy --manifest-path src-tauri/Cargo.toml --workspace --all-targets --all-features -- -D warnings",
      "cargo check --manifest-path src-tauri/Cargo.toml --workspace --all-targets --all-features",
      "cargo test --manifest-path src-tauri/Cargo.toml --workspace --all-features",
      "cargo deny --manifest-path src-tauri/Cargo.toml check",
      "typos ."
    ],
    "cargoDeny": "0.19.0",
    "typosCli": "1.44.0"
  },
  "miri": {
    "nightlyOnly": true,
    "toolchain": "nightly-2026-03-29",
    "command": "cargo +nightly-2026-03-29 miri test --manifest-path src-tauri/Cargo.toml --workspace --all-features",
    "note": "Pinned nightly chosen because miri is nightly-only and the component is present for x86_64-unknown-linux-gnu on 2026-03-29."
  },
  "note": "This file defines the enforced project quality posture. The TypeScript baseline stays on 5.9.x until stable typescript-eslint supports TypeScript 6."
}
